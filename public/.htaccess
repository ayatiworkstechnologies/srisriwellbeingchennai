Options -Indexes
RewriteEngine On

# 1. Map /contact-us to the /contact page
RewriteRule ^contact-us/?$ /contact [L,R=301]

# 2. Remove trailing slash and redirect to clean URL
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [L,R=301]

# 3. If request is a directory (trailing slash), serve the parent .html file
# e.g. /relaxationtherapy/ -> relaxationtherapy.html
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} ^/(.+?)/?$
RewriteCond %{DOCUMENT_ROOT}/%1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 4. Rewrite extensionless URLs to .html files (e.g. /contact -> contact.html)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# 5. Handle 404
ErrorDocument 404 /404.html
